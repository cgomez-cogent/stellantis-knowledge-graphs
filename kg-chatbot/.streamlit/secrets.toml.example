# Template for Streamlit Community Cloud → App settings → Secrets.
# Paste the contents below (with real values) into that panel — do NOT
# commit an actual secrets.toml file to the repo.

GOOGLE_API_KEY = "AIza..."

# Neo4j Aura (neo4j+s:// enables TLS, required by Aura)
NEO4J_URI = "neo4j+s://xxxxxxxx.databases.neo4j.io"
NEO4J_USER = "neo4j"
NEO4J_PASSWORD = "your-aura-password"
NEO4J_DATABASE = "neo4j"

# Optional — only needed if you use these providers/features
OPENAI_API_KEY = ""
ANTHROPIC_API_KEY = ""
GRAPHISTRY_KEY_ID = ""
GRAPHISTRY_KEY_SECRET = ""
