# ── Gemini (free tier) ──────────────────────────────────────────────────────
# Get your free key at: https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=AIza...

# ── Neo4j local (Docker) ────────────────────────────────────────────────────
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=yourpassword
NEO4J_DATABASE=neo4j

# ── Graphistry (graph visualization) ────────────────────────────────────────
# Get your keys at: https://hub.graphistry.com → API Keys
GRAPHISTRY_KEY_ID=your_personal_key_id
GRAPHISTRY_KEY_SECRET=your_personal_key_secret
